# Google Cloud / Gemini Enterprise Agent Platform mode.
# This uses local ADC (`gcloud auth application-default login`) in development.
GOOGLE_GENAI_USE_ENTERPRISE=true
GOOGLE_CLOUD_PROJECT=paslap
GOOGLE_CLOUD_LOCATION=global

# Optional deployment facts used by /api/health, /api/scan, and Launch Packet.
# SPEC_COMPASS_PUBLIC_URL=https://spec-compass-g3pfpanwsq-an.a.run.app
# SPEC_COMPASS_REGION=asia-northeast1
# SPEC_COMPASS_SERVICE=spec-compass

# Optional fallback for Gemini Developer API mode.
# GEMINI_API_KEY=
