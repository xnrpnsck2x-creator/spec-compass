{
  "name": "spec-compass-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @spec-compass/api\" \"npm run dev -w @spec-compass/web\"",
    "build": "npm run build -w @spec-compass/shared && npm run build -w @spec-compass/web && npm run build -w @spec-compass/api",
    "start": "npm run start -w @spec-compass/api",
    "test": "npm run build -w @spec-compass/shared && vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
